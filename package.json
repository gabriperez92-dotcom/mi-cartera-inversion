{
  "name": "inversion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "electron:build": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "build": {
    "appId": "com.gabri.inversion",
    "productName": "Mi Cartera de Inversión",
    "files": [
      "dist/**/*",
      "!dist/win-unpacked/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
